## 2. Cách implement phân quyền trong code

### 2.1. Hook `usePermissions`

**File mới:** `src/hooks/usePermissions.js`

```js
import { useAuthStore } from "../store/authStore";

export function usePermissions() {
  const { user } = useAuthStore();
  const role = user?.role || "sub_planner";
  const isMain = role === "main_planner" || role === "admin";
  const isSub = role === "sub_planner";
  const myLines = user?.assigned_lines || [];

  return {
    role, isMain, isSub, myLines,
    // Sidebar
    canSeeOrders: isMain,
    canSeeKHX: isMain,
    canSeeLapLich: true,         // cả hai, nhưng sub = read-only
    canSeeMyTasks: isSub,        // chỉ sub
    canSeeLineAssignment: isMain,
    canSeeConfig: isMain,
    canSeeTracking: isMain,
    canSeeMaterialETA: true,     // cả hai, sub lọc theo đơn
    // Wizard
    canEditStep: (step) => isMain || false,  // sub ko edit wizard trực tiếp
    canDispatch: isMain,
    canRunGA: isMain,
    canConfirmFinal: isMain,
    // Runs
    canCreateRun: isMain,
    canAcceptRun: isMain,
    canDeleteRun: isMain,
    canVerifyRun: isMain,
  };
}
```

### 2.2. Áp dụng vào Sidebar

**File `src/components/layout/Sidebar.jsx`:**

```jsx
import { usePermissions } from "../../hooks/usePermissions";

// Trong component:
const { canSeeOrders, canSeeKHX, canSeeMyTasks, canSeeLineAssignment, canSeeConfig, isSub } = usePermissions();

// Filter NAV_ITEMS dựa trên permissions:
const filteredNav = NAV_ITEMS.filter(item => {
  if (item.section) return true;
  if (item.to === "/orders" && !canSeeOrders) return false;
  if (item.to === "/khx-plan" && !canSeeKHX) return false;
  if (item.to === "/my-tasks" && !canSeeMyTasks) return false;
  if (item.to === "/line-assignments" && !canSeeLineAssignment) return false;
  // ... tương tự cho các mục khác
  return true;
});

// Thêm mục mới vào NAV_ITEMS:
{ to: "/my-tasks", label: "Công việc của tôi", Icon: ClipboardList },  // sub_planner
{ to: "/line-assignments", label: "Phân chuyền", Icon: GitBranch },    // main_planner
```

### 2.3. Áp dụng vào GAConfigPage (Wizard)

```jsx
const { isMain, isSub } = usePermissions();

// Sub-planner vào wizard → chế độ read-only toàn bộ
// Hiện banner: "Bạn đang xem ở chế độ tổng quan. Vào Công việc của tôi để thực hiện."
{isSub && (
  <div className="bg-blue-50 border border-blue-200 px-4 py-2 text-sm text-blue-700 flex items-center gap-2">
    <Info size={14} />
    Bạn đang xem tổng quan. <a href="/my-tasks" className="underline font-medium">Vào Công việc của tôi →</a>
  </div>
)}

// Truyền readOnly prop vào tất cả step components khi isSub
<Step1Orders readOnly={isSub} ... />
<Step2Capacity readOnly={isSub} ... />
```

### 2.4. Áp dụng vào RunsPage

```jsx
const { canCreateRun, canAcceptRun, canDeleteRun } = usePermissions();

// Ẩn nút "+ Lập lịch mới"
{canCreateRun && <button>+ Lập lịch mới</button>}

// Ẩn nút Chấp nhận/Xóa trên row
{canAcceptRun && r.lifecycle_status === "draft" && <button>Chấp nhận</button>}
{canDeleteRun && r.lifecycle_status !== "active" && <button><Trash2 /></button>}
```

